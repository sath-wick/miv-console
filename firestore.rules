rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == "admin";
    }

    function isCourier() {
      return signedIn() && request.auth.token.role == "courier";
    }

    function validOrderCreate() {
      return request.resource.data.status == "pending"
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.dateKey is string
        && request.resource.data.customerId is string
        && request.resource.data.customerName is string
        && request.resource.data.paymentTiming in ["prepaid", "postpaid", "monthly-settlement"]
        && request.resource.data.mealType in ["breakfast", "lunch", "dinner"]
        && request.resource.data.subtotalInPaise is int
        && request.resource.data.deliveryChargeInPaise is int
        && request.resource.data.grandTotalInPaise is int
        && request.resource.data.items is list;
    }

    function validCourierDeliveredUpdate() {
      return resource.data.status == "pending"
        && request.resource.data.status == "delivered"
        && request.resource.data.deliveredAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "deliveredAt"]);
    }

    match /users/{userId} {
      allow read: signedIn() && request.auth.uid == userId;
      allow write: false;
    }

    match /customers/{customerId} {
      allow read: isAdmin();
      allow write: isAdmin();
    }

    match /inventoryItems/{itemId} {
      allow read: isAdmin();
      allow write: isAdmin();
    }

    match /menus/{dateKey} {
      allow read: isAdmin();
      allow write: isAdmin();
    }

    match /orders/{orderId} {
      allow read: isAdmin() || isCourier();
      allow create: isAdmin() && validOrderCreate();
      allow update: isCourier() && validCourierDeliveredUpdate();
      allow delete: false;
    }

    match /payments/{paymentId} {
      allow read: isAdmin();
      allow write: isAdmin();
    }
  }
}
